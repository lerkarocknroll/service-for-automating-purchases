  "item": [
    {
      "name": "01. Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"first_name\": \"Иван\",\n    \"last_name\": \"Петров\",\n    \"email\": \"buyer@test.ru\",\n    \"password\": \"buyer123\",\n    \"company\": \"\",\n    \"position\": \"\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/user/register",
          "host": ["{{base_url}}"],
          "path": ["user", "register"]
        }
      }
    },
